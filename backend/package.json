{
  "name": "rep-ledger-backend",
  "version": "1.0.0",
  "description": "Rep Ledger - Backend API",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch --env-file=.env src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "prisma:generate": "prisma generate --schema=../schema.prisma",
    "prisma:migrate": "prisma migrate dev --schema=../schema.prisma",
    "prisma:deploy": "prisma migrate deploy --schema=../schema.prisma",
    "seed": "tsx ../seed.ts"
  },
  "dependencies": {
    "@prisma/client": "^5.22.0",
    "cors": "^2.8.5",
    "express": "^4.21.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/node": "^22.9.0",
    "prisma": "^5.22.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0"
  }
}
